# Dependencies
node_modules/

# Build outputs
dist/
out/
release/

# Temporary: end-user EXEs kept in-repo for orgs that block GitHub Release CDN.
# Prefer GitHub Releases long-term; remove installers/ when policy allows.
# Do NOT commit release/win-unpacked or other build junk.
installers/*
!installers/*.exe
!installers/README.md

# Local release packaging (combined zips can exceed GitHub 100MB)
rel_compressed/

# PV_DataForge (Python + Vue replica)
# PV_DataForge/**/node_modules/
# PV_DataForge/**/.venv/
# PV_DataForge/**/__pycache__/
# PV_DataForge/**/dist/
# PV_DataForge/data/
# PV_DataForge/**/*.sqlite

# TypeScript incremental
*.tsbuildinfo

# Logs & OS
*.log
.DS_Store
Thumbs.db
Desktop.ini

# Env / secrets
.env
.env.*
*.local

# Editors
.vscode/*
!.vscode/extensions.json
.idea/

# App runtime data (local SQLite / cache — never commit user data)
data/
*.sqlite
*.db
DataForge_user_cache

# Electron / native build cruft
*.node
.electron/
